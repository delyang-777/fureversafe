# Flask Configuration
SECRET_KEY=your-secret-key-change-in-production-12345678

# Database Configuration
# For Neon PostgreSQL (recommended):
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# For local PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/fureversafe

# For SQLite (development only):
# DATABASE_URL=sqlite:///fureversafe.db

# SQLAlchemy
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Email Configuration (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
# Use Gmail App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
MAIL_PASSWORD=your_app_password_here

# File Upload Settings
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=700971520

# Flask Environment
FLASK_ENV=development
FLASK_APP=app.py

# Optional: Flask Debug Mode
FLASK_DEBUG=True

# AI Chatbot Model
# GGUF is the primary backend (fast, low memory). Falls back to older GGUF builds, then LoRA if missing.
GGUF_MODEL_PATH=datasets/ai_model/fureversafe-q4_k_m-v2.gguf
GGUF_N_GPU_LAYERS=-1
GGUF_N_CTX=1024

# Flask forwards chat requests to the standalone AI service.
AI_SERVER_URL=http://127.0.0.1:5000

# LoRA fallback (only used if GGUF model file is missing)
LORA_MODEL_PATH=datasets/fureversafe_lora_model
LORA_BASE_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Shared inference settings
AI_MAX_NEW_TOKENS=200
AI_TEMPERATURE=0.2
